# Copy to .env and fill in. Keys stay server-side only.

# --- Chat: word auto-define + podcast script writing ---
OPENAI_API_KEY=sk-...
PORT=3000

# Optional: route chat at an OpenAI-compatible proxy/gateway instead of the real
# API. Must include the version prefix; the app appends "/chat/completions".
# Leave unset to use https://api.openai.com/v1 directly.
# OPENAI_BASE_URL=http://localhost:8080/v1

# --- TTS: AI podcast MP3 (uses "/audio/speech") ---
# Optional. Set these only if TTS should use a different provider/key than chat
# (e.g. chat goes through a proxy that has no speech endpoint). When
# OPENAI_TTS_API_KEY is set, TTS defaults to https://api.openai.com/v1 unless
# OPENAI_TTS_BASE_URL overrides it. If unset, TTS reuses OPENAI_API_KEY/OPENAI_BASE_URL.
# OPENAI_TTS_API_KEY=sk-...
# OPENAI_TTS_BASE_URL=https://api.openai.com/v1
