# Copy to .env and fill in. The OpenAI key stays server-side only.
OPENAI_API_KEY=sk-...
PORT=3000

# Optional: point the app at an OpenAI-compatible proxy/gateway instead of the
# real API. Must include the version prefix; the app appends "/chat/completions"
# and "/audio/speech". Leave unset to use https://api.openai.com/v1 directly.
# OPENAI_BASE_URL=http://localhost:8080/v1
